{
  "name": "@useimpel/eve-kit",
  "version": "1.3.0",
  "description": "Eve helpers and AI SDK provider for Impel gateway-backed agents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/UseImpel/eve-kit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "eve-kit-smoke-deployed": "./dist/bin/eve-kit-smoke-deployed.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts/run-token": {
      "types": "./dist/contracts/run-token.d.ts",
      "import": "./dist/contracts/run-token.js"
    },
    "./contracts/eve-protocol": {
      "types": "./dist/contracts/eve-protocol.d.ts",
      "import": "./dist/contracts/eve-protocol.js"
    },
    "./contracts/inference-admin": {
      "types": "./dist/contracts/inference-admin.d.ts",
      "import": "./dist/contracts/inference-admin.js"
    },
    "./contracts/ingestion": {
      "types": "./dist/contracts/ingestion.d.ts",
      "import": "./dist/contracts/ingestion.js"
    },
    "./eve": {
      "types": "./dist/eve/index.d.ts",
      "import": "./dist/eve/index.js"
    },
    "./eve/channel": {
      "types": "./dist/eve/channel.d.ts",
      "import": "./dist/eve/channel.js"
    },
    "./eve/workspace-tools": {
      "types": "./dist/eve/workspace-tools.d.ts",
      "import": "./dist/eve/workspace-tools.js"
    },
    "./eve/code-intelligence-tools": {
      "types": "./dist/eve/code-intelligence-tools.d.ts",
      "import": "./dist/eve/code-intelligence-tools.js"
    },
    "./eve/database-intelligence-tools": {
      "types": "./dist/eve/database-intelligence-tools.d.ts",
      "import": "./dist/eve/database-intelligence-tools.js"
    },
    "./eve/web-search-tool": {
      "types": "./dist/eve/web-search-tool.d.ts",
      "import": "./dist/eve/web-search-tool.js"
    },
    "./eve/gateway": {
      "types": "./dist/eve/gateway.d.ts",
      "import": "./dist/eve/gateway.js"
    },
    "./eve/cli-runner": {
      "types": "./dist/eve/cli-runner.d.ts",
      "import": "./dist/eve/cli-runner.js"
    },
    "./eve/connections/claude-bridge": {
      "types": "./dist/eve/connections/claude-bridge.d.ts",
      "import": "./dist/eve/connections/claude-bridge.js"
    },
    "./eve/sandbox": {
      "types": "./dist/eve/sandbox.d.ts",
      "import": "./dist/eve/sandbox.js"
    },
    "./eve/render-ui": {
      "types": "./dist/eve/render-ui.d.ts",
      "import": "./dist/eve/render-ui.js"
    },
    "./eve/evals": {
      "types": "./dist/eve/evals.d.ts",
      "import": "./dist/eve/evals.js"
    },
    "./eve/runtime": {
      "types": "./dist/eve/runtime.d.ts",
      "import": "./dist/eve/runtime.js"
    },
    "./eve/bridge": {
      "types": "./dist/eve/bridge.d.ts",
      "import": "./dist/eve/bridge.js"
    },
    "./eve/telegram": {
      "types": "./dist/eve/telegram.d.ts",
      "import": "./dist/eve/telegram.js"
    },
    "./eve/whatsapp": {
      "types": "./dist/eve/whatsapp/index.d.ts",
      "import": "./dist/eve/whatsapp/index.js"
    },
    "./eve/catalog": {
      "types": "./dist/eve/catalog.d.ts",
      "import": "./dist/eve/catalog.js"
    },
    "./retrieval": {
      "types": "./dist/retrieval/index.d.ts",
      "import": "./dist/retrieval/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "fixtures/gateway-pilot-eve/package.json",
    "fixtures/gateway-pilot-eve/tsconfig.json",
    "fixtures/gateway-pilot-eve/agent",
    "fixtures/gateway-pilot-eve/evals",
    "MIGRATION.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node --input-type=module -e \"import { chmodSync } from 'node:fs'; chmodSync('dist/bin/eve-kit-smoke-deployed.js', 0o755)\"",
    "check": "npm run build && npm run typecheck:pilot:gateway:eve && npm test",
    "pilot:gateway": "node scripts/pilot-gateway.mjs",
    "pilot:gateway:eve": "npm run prepare:pilot:gateway:eve && cd fixtures/gateway-pilot-eve && eve eval gateway-pilot --strict --skip-report --max-concurrency 1",
    "prepare:pilot:gateway:eve": "node scripts/prepare-pilot-gateway-eve.mjs",
    "typecheck:pilot:gateway:eve": "npm run prepare:pilot:gateway:eve && tsc -p fixtures/gateway-pilot-eve/tsconfig.json",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.10",
    "@ai-sdk/openai": "4.0.9",
    "@ai-sdk/provider": "4.0.2",
    "@ai-sdk/xai": "4.0.9",
    "@vercel/connect": "0.3.2",
    "ai": "7.0.18",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "eve": "0.22.1",
    "just-bash": "3.1.0"
  },
  "peerDependenciesMeta": {
    "eve": {
      "optional": true
    },
    "just-bash": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "braintrust": "3.21.0",
    "eve": "0.22.1",
    "just-bash": "3.1.0",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT"
}
