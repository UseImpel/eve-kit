{
  "name": "@useimpel/ai-sdk-provider-impel-inference",
  "version": "0.1.1",
  "description": "AI SDK provider that routes LanguageModelV3 calls through Impel's durable inference service.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/UseImpel/ai-sdk-provider-impel-inference.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/provider-utils": "5.0.0-beta.49",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "4.0.0-beta.19"
  },
  "devDependencies": {
    "@ai-sdk/provider": "4.0.0-beta.19",
    "@types/node": "^24.5.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT"
}
