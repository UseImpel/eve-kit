{
  "name": "@useimpel/eve-kit",
  "version": "0.2.23",
  "description": "Eve helpers and AI SDK provider for Impel's durable inference service.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/UseImpel/eve-kit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "eve-kit-smoke-deployed": "./dist/bin/eve-kit-smoke-deployed.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eve": {
      "types": "./dist/eve/index.d.ts",
      "import": "./dist/eve/index.js"
    },
    "./eve/channel": {
      "types": "./dist/eve/channel.d.ts",
      "import": "./dist/eve/channel.js"
    },
    "./eve/gateway": {
      "types": "./dist/eve/gateway.d.ts",
      "import": "./dist/eve/gateway.js"
    },
    "./eve/connections/claude-bridge": {
      "types": "./dist/eve/connections/claude-bridge.d.ts",
      "import": "./dist/eve/connections/claude-bridge.js"
    },
    "./eve/sandbox": {
      "types": "./dist/eve/sandbox.d.ts",
      "import": "./dist/eve/sandbox.js"
    },
    "./eve/render-ui": {
      "types": "./dist/eve/render-ui.d.ts",
      "import": "./dist/eve/render-ui.js"
    },
    "./eve/evals": {
      "types": "./dist/eve/evals.d.ts",
      "import": "./dist/eve/evals.js"
    },
    "./eve/runtime": {
      "types": "./dist/eve/runtime.d.ts",
      "import": "./dist/eve/runtime.js"
    },
    "./eve/bridge": {
      "types": "./dist/eve/bridge.d.ts",
      "import": "./dist/eve/bridge.js"
    },
    "./retrieval": {
      "types": "./dist/retrieval/index.d.ts",
      "import": "./dist/retrieval/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/provider-utils": "5.0.0-beta.49",
    "ai": "^6.0.208",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "4.0.0-beta.19",
    "ai-sdk-provider-claude-code": "3.5.0",
    "eve": "^0.11.6",
    "just-bash": "3.0.1"
  },
  "peerDependenciesMeta": {
    "ai-sdk-provider-claude-code": {
      "optional": true
    },
    "eve": {
      "optional": true
    },
    "just-bash": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "4.0.0-beta.19",
    "@types/node": "^24.5.2",
    "ai-sdk-provider-claude-code": "3.5.0",
    "braintrust": "^3.18.0",
    "eve": "^0.11.6",
    "just-bash": "3.0.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT"
}
